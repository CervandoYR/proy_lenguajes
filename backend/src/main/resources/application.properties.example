spring.application.name=ecommerce
server.port=9001

spring.datasource.url=jdbc:mysql://localhost:3306/dbEcommerce?createDatabaseIfNotExist=true
spring.datasource.username=${DB_USERNAME:root}
spring.datasource.password=${DB_PASSWORD:password_aqui}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

spring.jpa.hibernate.ddl-auto=update
spring.jpa.database-platform=org.hibernate.dialect.MySQLDialect
spring.jpa.show-sql=false

# JWT Secret (>= 256-bit secure key required by JJWT HS256)
jwt.secret=${JWT_SECRET:ServitekSuperSecureJwtSecretKey2026ForLocalDevelopmentAndProductionUse99!}
jwt.expiration=86400000

# Cloudinary Config
cloudinary.cloud-name=${CLOUDINARY_CLOUD_NAME:tu_cloud_name_aqui}
cloudinary.api-key=${CLOUDINARY_API_KEY:tu_api_key_aqui}
cloudinary.api-secret=${CLOUDINARY_API_SECRET:tu_api_secret_aqui}

# Culqi Config
culqi.private-key=${CULQI_PRIVATE_KEY:sk_test_dummy_key_replace_me}

# Limite de subida de archivos (imagenes de productos)
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB
gemini.api-key=PON_TU_API_KEY_DE_GEMINI_AQUI
